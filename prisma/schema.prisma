generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider  = "postgresql"

  url       = env("DATABASE_URL")

  directUrl = env("DIRECT_URL")

}



model User {

  id           String        @id @default(cuid())

  name         String

  email        String        @unique

  passwordHash String

  role         String        @default("USER")

  createdAt    DateTime      @default(now())

  updatedAt    DateTime      @updatedAt

  problems     Problem[]

  applications Application[]

  notes        Note[]

  projects     Project[]

  activities   Activity[]

}



model Problem {

  id            String    @id @default(cuid())

  userId        String

  name          String

  url           String?

  topic         String

  pattern       String?

  confidence    Int       @default(3)

  notes         String?

  lastPracticed DateTime  @default(now())

  nextReview    DateTime?

  revisitCount  Int       @default(1)

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([userId, name])

  @@index([userId, nextReview])

  @@index([userId, topic])

}



model Application {

  id         String    @id @default(cuid())

  userId     String

  company    String

  role       String

  jobId      String?

  jobUrl     String?

  location   String?

  status     String    @default("WISHLIST")

  resumeFileName   String?

  resumeFilePath   String?

  resumeFileSize   Int?

  resumeUploadedAt DateTime?

  nextAction String?

  notes      String?

  appliedAt  DateTime?

  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([userId, company, role])

  @@index([userId, status])

}



model Note {

  id        String   @id @default(cuid())

  userId    String

  title     String

  body      String

  tag       String

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model Project {

  id        String   @id @default(cuid())

  userId    String

  title     String

  status    String   @default("ACTIVE")

  nextStep  String?

  notes     String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, status])

}



model Activity {

  id        String   @id @default(cuid())

  userId    String

  label     String

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, createdAt])

}


